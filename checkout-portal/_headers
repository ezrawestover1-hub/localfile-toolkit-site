/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.paddle.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.paddle.com; connect-src https://*.paddle.com; frame-src https://*.paddle.com; font-src 'none'; object-src 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'
